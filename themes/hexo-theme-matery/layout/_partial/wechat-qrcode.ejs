<style>
    .mobiledevice {
        display: none !important;
    }
    /*微信二维码*/
    .wechat_qrcode {
        position: absolute;
        margin-left: 10px;
        bottom: 10px;
        background: url('<%- url_for(theme.socialLink.wechat[0]) %>');
    }

    .wechat:hover .wechat_qrcode {
        width: 200px;
        height: 200px;
    }

    @media only screen and (max-width: 601px) {
        .wechat {
            display: none !important;
        }
        .mobiledevice {
            display: inline-block !important;
        }
    }
</style>

<a href="javascript:;" class="wechat" data-position="top" data-delay="50">
    <i class="fab fa-weixin"></i>
    <img class="wechat_qrcode">
</a>

<a href="javascript:;" class="tooltipped mobiledevice" data-tooltip="微信: <%= theme.socialLink.wechat[1] %>" data-position="top" data-delay="50">
    <i class="fab fa-weixin"></i>
</a>